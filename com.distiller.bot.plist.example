<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.distiller.bot</string>

    <key>ProgramArguments</key>
    <array>
        <string>/path/to/distiller/scripts/run_bot.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/path/to/distiller</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/home/USERNAME/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/home/USERNAME</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/path/to/distiller/logs/bot.out</string>

    <key>StandardErrorPath</key>
    <string>/path/to/distiller/logs/bot.err</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
