# Anthropic Claude API（雞尾酒推薦個人化說明，選填）
# 設定後 LINE Bot 推薦結果會附加 Claude 生成的品酒師說明
ANTHROPIC_API_KEY=

# LINE Messaging API（推播通知）
# 從 LINE Developers Console 取得：https://developers.line.biz/
# 與 music-collector 共用同一組憑證
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# GCS 設定（Cloud Run 環境專用）
# 本機開發留空即可，不設定時程式維持本機行為
GCS_BUCKET=
GCS_DB_BLOB=distiller.db

# Cloud Run 設定（Cloud Run 環境專用）
# bot.py 用來觸發 Cloud Run Jobs API
GOOGLE_CLOUD_PROJECT=
CLOUD_RUN_REGION=asia-east1
SCRAPER_JOB_NAME=distiller-scraper
